# Riffado deployment env for plaudautomation — SANITIZED TEMPLATE.
# Copy to `.env` (gitignored) and fill secrets. Never commit the real .env.
#
#   cp .env.example .env
#   # then generate secrets:
#   #   openssl rand -hex 32   -> BETTER_AUTH_SECRET
#   #   openssl rand -hex 32   -> ENCRYPTION_KEY
#   #   openssl rand -hex 24   -> POSTGRES_PASSWORD

# --- Pinned release (SEC-01: never `latest`) ---
# 0.5.6 — 0.5.4/0.5.3 have a rate-limiter bug (ERR_INVALID_ARG_TYPE) that
# crashes every /api/v1/* and /api/plaud/sync request; fixed in 0.5.5.
RIFFADO_VERSION=0.5.6

# --- Secrets (generate locally; do not reuse the examples) ---
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=

# --- Local-only app config ---
APP_URL=http://127.0.0.1:3000
# Set to true AFTER creating your single admin user, then `docker compose up -d`
# to recreate the app container locked down.
DISABLE_REGISTRATION=false

# --- Intentionally NOT set (kept off for the privacy gate) ---
# DEFAULT_STORAGE_TYPE stays `local` (set in compose). No S3_* values.
# No SMTP_* (email off). No WEBSHARE_API_KEY / PLAUD_PROXY_SCOPE (direct to
# Plaud, no third-party proxy). No RYBBIT_* (analytics; hosted-only anyway).
# No ADMIN_EMAILS / IS_HOSTED (admin dashboard is hosted-only & inert).
# DISABLE_UPDATE_CHECK is forced true in compose (no api.github.com calls).
